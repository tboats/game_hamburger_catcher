{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PARA Library Catalog",
  "description": "Validates catalog.yml for workflows, rules, and skills libraries.",
  "type": "object",
  "required": ["version", "library", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version. Currently must be 1.",
      "enum": [1]
    },
    "library": {
      "type": "string",
      "description": "Library type.",
      "enum": ["workflows", "rules", "skills"]
    },
    "description": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "kernel_min", "entrypoint", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Stable kebab-case identifier."
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Deprecated (v1.7.13). Use VERSIONS.yml instead. Kept for backward compatibility."
          },
          "kernel_min": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "kernel_max": {
            "type": "string",
            "description": "Optional. Omit if compatible with all future versions."
          },
          "entrypoint": {
            "type": "string",
            "description": "Relative path to the markdown file."
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
